# Copy to .env and fill in. Never commit .env.
#
# Tip: most of these can be set or rotated from the local web UI
# (`training-brain web`) — it writes back to this file atomically.

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Modern secret key (sb_secret_...): write access for sync jobs. Treat as secret.
# Find under Project Settings → API Keys. Use the modern key, not the legacy
# service_role JWT — modern keys rotate independently of the publishable key.
SUPABASE_SECRET_KEY=

# --- Garmin Connect ---
# Optional but recommended. With these set, the sync transparently refreshes
# the cached Garmin token when it expires and silently re-logs in when the
# refresh token dies — so cron survives token rotation. Without them, an
# expired session is a hard failure that needs manual re-auth via the web UI.
#
# Tokens cache to ~/.garminconnect/ after the first interactive login
# (`training-brain login-garmin`, or the Garmin card in the web UI). The web
# UI writes confirmed credentials back to this file on every successful login.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- TrainingPeaks ---
# Personal iCal feed URL — find in TrainingPeaks under
# Settings → Account Settings → Sharing → Calendar Feed.
# Includes a token, so treat as secret. The web UI can update this for you
# and probe the feed to confirm it's reachable.
TP_ICAL_URL=

# --- Strava (optional) ---
# Create an API app at https://www.strava.com/settings/api and set its
# Authorization Callback Domain to `localhost`. The web UI handles the full
# OAuth dance — opening the Strava card and clicking "Authorize on Strava"
# populates all three fields below for you.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Generated by the OAuth flow; rotate if it leaks.
STRAVA_REFRESH_TOKEN=

# --- Athlete ---
# Used as the default athlete_id for ingested data. Generate by inserting
# your athlete row in Supabase (see README setup step 3) and copy the
# returned UUID here.
ATHLETE_ID=
