# Copy to .env and fill in. Never commit .env.

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key: write access for sync jobs. Treat as secret.
SUPABASE_SERVICE_KEY=

# --- Garmin Connect ---
# garth handles MFA the first time you log in interactively, then caches tokens
# in ~/.garth/. After that, sync jobs run unattended.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- TrainingPeaks ---
# Personal iCal feed URL — find in TrainingPeaks under
# Settings → Account Settings → Sharing → Calendar Feed.
# Includes a token, so treat as secret.
TP_ICAL_URL=

# --- Strava (optional) ---
# Create an API app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Generated by the OAuth flow; rotate if it leaks.
STRAVA_REFRESH_TOKEN=

# --- Athlete ---
# Used as the default athlete_id for ingested data. UUID generated by the
# initial migration; copy it here after running migrations.
ATHLETE_ID=
